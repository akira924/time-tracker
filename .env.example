# Slack Incoming Webhook URL — required
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Optional overrides
# IANA timezone name. America/Chicago auto-handles CDT (summer) / CST (winter).
TZ_NAME=America/Chicago

# Cron expression. Default fires at the top of 8,10,12,14,16,18,20,22 every day.
CRON_SCHEDULE=0 8,10,12,14,16,18,20,22 * * *
